# Copy to .env and adjust as needed

# gRPC addresses of all kvnodes (comma-separated)
RAFTDRIVE_KV_TARGETS=localhost:50050,localhost:50051,localhost:50052

# S3 settings
RAFTDRIVE_S3_BUCKET=raftdrive-objects
RAFTDRIVE_S3_REGION=us-east-1

# LocalStack (dev) — remove or leave empty to use real AWS S3
RAFTDRIVE_S3_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# RaftDrive REST port
RAFTDRIVE_PORT=8080
